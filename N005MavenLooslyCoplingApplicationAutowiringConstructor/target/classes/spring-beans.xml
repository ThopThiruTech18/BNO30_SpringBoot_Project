<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean  id="upi" class="in.thiruit.UPIPayment" ></bean>
    <bean  id="debit" class="in.thiruit.DebitcardPayment" primary="true"></bean>
    <bean  id="credit" class="in.thiruit.CreditCardPayment" ></bean>
    
    
    <bean  id="pp" class="in.thiruit.PaymentProcess" autowire="constructor"></bean>

</beans>